WANDB_API_KEY=

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=synth
POSTGRES_USER=postgres
POSTGRES_PASSWORD=PASSWORD

VALIDATOR_COLDKEY_NAME=
VALIDATOR_HOTKEY_NAME=
NETWORK=
NETUID=
LOG_ID_PREFIX=

# Pyth data backend. `hermes` (default) keeps the legacy
# benchmarks.pyth.network + hermes.pyth.network endpoints. `pro` switches
# the validator to https://pyth.dourolabs.app/v1/real_time/history (public)
# and the miner's get_asset_price to Pyth Lazer
# https://pyth-lazer.dourolabs.app/v1/latest_price (requires PYTH_API_KEY).
PYTH_BACKEND=hermes
# Free Bearer token from pythdata.app -> Pyth Terminal. Only required when
# PYTH_BACKEND=pro.
PYTH_API_KEY=
